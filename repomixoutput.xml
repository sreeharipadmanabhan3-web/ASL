@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap');
@import "tailwindcss";

:root {
  font-family: 'Outfit', 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  color-scheme: dark;
}

html,
body {
  margin: 0;
  padding: 0;
  height: 100%;
  background-color: #000000;
  color: rgba(255, 255, 255, 0.9);
  overflow: hidden;
}

#root {
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* Animations */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(16px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.95) translateY(-8px);
  }

  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(20px);
  }

  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes orbFloat1 {
  0% {
    transform: translate(0, 0) scale(1);
  }

  50% {
    transform: translate(60px, -80px) scale(1.15);
  }

  100% {
    transform: translate(0, 0) scale(1);
  }
}

@keyframes orbFloat2 {
  0% {
    transform: translate(0, 0) scale(1.1);
  }

  50% {
    transform: translate(-70px, 50px) scale(0.9);
  }

  100% {
    transform: translate(0, 0) scale(1.1);
  }
}

@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }

  100% {
    background-position: 200% 0;
  }
}

@keyframes pulseRingEmerald {
  0% {
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
  }

  70% {
    box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
  }

  100% {
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
  }
}

@keyframes pulseRingRed {
  0% {
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4);
  }

  70% {
    box-shadow: 0 0 0 10px rgba(239, 68, 68, 0);
  }

  100% {
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
  }
}

@keyframes pulseRingMint {
  0% {
    box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.4);
  }

  70% {
    box-shadow: 0 0 0 10px rgba(52, 211, 153, 0);
  }

  100% {
    box-shadow: 0 0 0 0 rgba(52, 211, 153, 0);
  }
}

@keyframes caretBlink {

  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0;
  }
}

/* Classes */
.animate-fade-up {
  animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.animate-fade-in {
  animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.animate-scale-in {
  animation: scaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.animate-slide-in-right {
  animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.animate-float-1 {
  animation: orbFloat1 20s ease-in-out infinite;
}

.animate-float-2 {
  animation: orbFloat2 25s ease-in-out infinite;
}

.animate-caret {
  animation: caretBlink 1s step-end infinite;
}

/* Glassmorphism Design Language */
.glass-panel {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 100%);
  backdrop-filter: blur(32px);
  -webkit-backdrop-filter: blur(32px);
  border: 1px solid rgba(255, 255, 255, 0.12);
  box-shadow:
    0 24px 64px -16px rgba(0, 0, 0, 0.7),
    inset 0 1px 1px rgba(255, 255, 255, 0.15);
}

.glass-panel-hover {
  transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

.glass-panel-hover:hover {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 100%);
  border-color: rgba(255, 255, 255, 0.18);
  box-shadow:
    0 32px 80px -12px rgba(0, 0, 0, 0.85),
    inset 0 1px 1.5px rgba(255, 255, 255, 0.22);
  transform: translateY(-2px);
}

.glass-input {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.glass-input:focus {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(16, 185, 129, 0.4);
  box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.12);
  outline: none;
}

.bg-grid-pattern {
  background-size: 40px 40px;
  background-image:
    linear-gradient(to right, rgba(255, 255, 255, 0.015) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
}

/* Custom Scrollbars */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 9999px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.15);
}

/* Pulsing Status Badges */
.pulse-ring-emerald {
  animation: pulseRingEmerald 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

.pulse-ring-red {
  animation: pulseRingRed 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

.pulse-ring-mint {
  animation: pulseRingMint 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* High-Tech Camera HUD Scanning Styles */
@keyframes scanline {
  0% {
    transform: translateY(-100%);
  }

  100% {
    transform: translateY(100%);
  }
}

.hud-scanline {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom,
      rgba(16, 185, 129, 0) 0%,
      rgba(16, 185, 129, 0.03) 15%,
      rgba(16, 185, 129, 0.12) 50%,
      rgba(16, 185, 129, 0.03) 85%,
      rgba(16, 185, 129, 0) 100%);
  height: 10px;
  opacity: 0.7;
  pointer-events: none;
  animation: scanline 6s linear infinite;
}

.hud-grid-overlay {
  position: absolute;
  inset: 0;
  background-size: 32px 32px;
  background-image:
    radial-gradient(circle, rgba(16, 185, 129, 0.03) 1px, transparent 1px);
  pointer-events: none;
}

.tech-bracket-tl,
.tech-bracket-tr,
.tech-bracket-bl,
.tech-bracket-br {
  position: absolute;
  width: 16px;
  height: 16px;
  pointer-events: none;
  z-index: 15;
}

.tech-bracket-tl {
  top: 16px;
  left: 16px;
  border-top: 2px solid rgba(16, 185, 129, 0.35);
  border-left: 2px solid rgba(16, 185, 129, 0.35);
}

.tech-bracket-tr {
  top: 16px;
  right: 16px;
  border-top: 2px solid rgba(16, 185, 129, 0.35);
  border-right: 2px solid rgba(16, 185, 129, 0.35);
}

.tech-bracket-bl {
  bottom: 16px;
  left: 16px;
  border-bottom: 2px solid rgba(16, 185, 129, 0.35);
  border-left: 2px solid rgba(16, 185, 129, 0.35);
}

.tech-bracket-br {
  bottom: 16px;
  right: 16px;
  border-bottom: 2px solid rgba(16, 185, 129, 0.35);
  border-right: 2px solid rgba(16, 185, 129, 0.35);
}

/* Shifting background gradient animation */
@keyframes gradientAnimation {
  0% {
    background-position: 0% 50%;
  }

  50% {
    background-position: 100% 50%;
  }

  100% {
    background-position: 0% 50%;
  }
}

.animate-bg-fluid {
  background: linear-gradient(-45deg, #030303, #071510, #051015, #030303);
  background-size: 400% 400%;
  animation: gradientAnimation 24s ease infinite;
}

/* Shifting color animations for background orbs */
@keyframes orbColorChange1 {

  0%,
  100% {
    background-color: rgba(16, 185, 129, 0.04);
  }

  50% {
    background-color: rgba(6, 182, 212, 0.04);
  }
}

@keyframes orbColorChange2 {

  0%,
  100% {
    background-color: rgba(20, 184, 166, 0.04);
  }

  50% {
    background-color: rgba(139, 92, 246, 0.04);
  }
}

.animate-orb-color-1 {
  animation: orbFloat1 20s ease-in-out infinite, orbColorChange1 12s ease-in-out infinite;
}

.animate-orb-color-2 {
  animation: orbFloat2 25s ease-in-out infinite, orbColorChange2 15s ease-in-out infinite;
